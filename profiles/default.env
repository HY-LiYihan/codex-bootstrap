# Default Codex Bootstrap profile.
# Values can be overridden by environment variables before running install.sh.
: "${CODEX_MODEL:=gpt-5.5}"
: "${CODEX_REASONING_EFFORT:=high}"
: "${CODEX_MODEL_VERBOSITY:=medium}"
: "${CODEX_REASONING_SUMMARY:=auto}"
: "${CODEX_WEB_SEARCH:=live}"
: "${CODEX_PROJECT_DOC_MAX_BYTES:=65536}"
: "${CODEX_REQUEST_MAX_RETRIES:=4}"
: "${CODEX_STREAM_MAX_RETRIES:=5}"
: "${CODEX_STREAM_IDLE_TIMEOUT_MS:=300000}"
: "${CODEX_SECURITY_PROFILE:=max}"
export CODEX_MODEL CODEX_REASONING_EFFORT CODEX_MODEL_VERBOSITY CODEX_REASONING_SUMMARY CODEX_WEB_SEARCH
export CODEX_PROJECT_DOC_MAX_BYTES CODEX_REQUEST_MAX_RETRIES CODEX_STREAM_MAX_RETRIES CODEX_STREAM_IDLE_TIMEOUT_MS
export CODEX_SECURITY_PROFILE
